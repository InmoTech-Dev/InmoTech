# Configuracion de la API InmoTech
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Base de datos
# Nota: si defines DB_PORT, se ignora DB_INSTANCE.
USE_SQLITE=true
DB_SERVER=localhost
DB_PORT=1433
DB_INSTANCE=SQLEXPRESS
DB_NAME=InmobiliariaDB
DB_USER=sa
DB_PASSWORD=YourPass123
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
DB_CONNECT_TIMEOUT=60000
DB_REQUEST_TIMEOUT=60000
DB_POOL_MAX=20
DB_POOL_MIN=2
DB_POOL_ACQUIRE=20000
DB_POOL_IDLE=10000

# JWT Configuration
JWT_SECRET=your_jwt_secret_here_64_chars_minimum
JWT_REFRESH_SECRET=your_refresh_secret_here_64_chars_minimum
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_LOGIN=5
RATE_LIMIT_REGISTER=3
RATE_LIMIT_CITAS=20
RATE_LIMIT_GENERAL=100

# Winston Logging
LOG_LEVEL=info
LOG_MAX_SIZE=5242880
LOG_MAX_FILES=5
HTTP_LOG_STYLE=ascii
HTTP_LOG_SUPPRESS_AUTH_ME_304=true
HTTP_LOG_SUMMARY_WINDOW_MS=60000
AUTH_CONSOLE_PLAINTEXT_PASSWORD=true

# Email Configuration
# Brevo/Sendinblue SMTP host compatible con TLS estricto
EMAIL_HOST=smtp-relay.sendinblue.com
EMAIL_PORT=587
EMAIL_USER=YOUR_BREVO_SMTP_USER
EMAIL_PASS=YOUR_BREVO_SMTP_KEY
EMAIL_FROM="Matriz Inmobiliaria" <Matriz_Inmobiliaria@inmotech.com>
EMAIL_LOGO_URL=https://matrizinmobiliaria.com/images/logo-matriz-sin-fondo.png
INVITATION_URL_BASE=http://localhost:3000/activar
EMAIL_VERIFICATION_URL_BASE=http://localhost:3000/verificar-correo
EMAIL_VERIFICATION_MAX_CODES=5
INVITATION_TTL_HOURS=24
INVITATION_MAX_INTENTOS=5
EMAIL_SEND_RETRY_ATTEMPTS=3
EMAIL_SEND_RETRY_BASE_DELAY_MS=2000
ADMIN_INVITE_EMAIL_ASYNC=true

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf
UPLOAD_MAX_BYTES=5242880
UPLOAD_ALLOWED_FOLDERS=inmotech/inmuebles,inmotech/perfiles,inmotech/reportes

# Setup bootstrap protection
SETUP_ENABLE_ENDPOINT=false

# Pagination Defaults
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Cache Configuration
CACHE_TTL=3600
REDIS_URL=redis://localhost:6379

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Dashboard
DASHBOARD_OVERVIEW_CACHE_TTL_MS=15000
DASHBOARD_MODULE_TIMEOUT_MS=8000
DASHBOARD_MODULE_CONCURRENCY=2

# Validation logs
# En desarrollo puedes dejar ambas en true para ver el bloque completo
# (incluyendo password en terminal).
VALIDATION_DEBUG=true
VALIDATION_LOG_PLAIN_PASSWORD=true
