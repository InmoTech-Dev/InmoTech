# Configuración de la API InmoTech
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Base de datos (desarrollo: SQLite, producción: SQL Server)
USE_SQLITE=true
DB_SERVER=localhost\\SQLEXPRESS
DB_PORT=1433
DB_NAME=InmobiliariaDB
DB_USER=sa
DB_PASSWORD=YourPass123
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# JWT Configuration
JWT_SECRET=your_jwt_secret_here_64_chars_minimum
JWT_REFRESH_SECRET=your_refresh_secret_here_64_chars_minimum
JWT_EXPIRE=1h
JWT_REFRESH_EXPIRE=7d

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_LOGIN=5
RATE_LIMIT_REGISTER=3
RATE_LIMIT_CITAS=20
RATE_LIMIT_GENERAL=100

# Winston Logging
LOG_LEVEL=info
LOG_MAX_SIZE=5242880
LOG_MAX_FILES=5

# Email Configuration (SendGrid - recomendado para prod y con plan free)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USER=apikey
EMAIL_PASS=YOUR_SENDGRID_API_KEY
EMAIL_FROM="Matriz Inmobiliaria" <Matriz_Inmobiliaria@inmotech.com>
EMAIL_LOGO_URL=https://matrizinmobiliaria.com/images/logo-matriz-sin-fondo.png
INVITATION_URL_BASE=http://localhost:3000/activar
EMAIL_VERIFICATION_URL_BASE=http://localhost:3000/verificar-correo
EMAIL_VERIFICATION_MAX_CODES=5
INVITATION_TTL_HOURS=24
INVITATION_MAX_INTENTOS=5

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# Pagination Defaults
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Cache Configuration
CACHE_TTL=3600
REDIS_URL=redis://localhost:6379

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
