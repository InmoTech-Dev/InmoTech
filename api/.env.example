quiero q# =====================================================
# CONFIGURACION DE BASE DE DATOS SQL SERVER
# =====================================================

# Conexion primaria. Pon aqui la BD remota cuando la tengas.
DB_SERVER=remote-sql-host
DB_INSTANCE=
DB_PORT=1433
DB_NAME=InmobiliariaDB
DB_USER=sa
DB_PASSWORD=change-me
DB_DIALECT=mssql
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=false
DB_POOL_MAX=30
DB_POOL_MIN=5
DB_CONNECT_TIMEOUT=8000
DB_REQUEST_TIMEOUT=8000
DB_MAX_RETRIES=0
DB_RETRY_DELAY_MS=1000

# Conexion de respaldo local. Se usa si la primaria falla.
DB_FALLBACK_SERVER=localhost
DB_FALLBACK_INSTANCE=
DB_FALLBACK_PORT=1433
DB_FALLBACK_NAME=InmobiliariaDB
DB_FALLBACK_USER=sa
DB_FALLBACK_PASSWORD=12345678
DB_FALLBACK_ENCRYPT=true
DB_FALLBACK_TRUST_SERVER_CERTIFICATE=true
DB_FALLBACK_CONNECT_TIMEOUT=8000
DB_FALLBACK_REQUEST_TIMEOUT=8000

# =====================================================
# CONFIGURACION DEL SERVIDOR
# =====================================================

PORT=5000
NODE_ENV=development
API_VERSION=v1

# =====================================================
# CONFIGURACION DE SEGURIDAD
# =====================================================

JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

COOKIE_SECURE=false
COOKIE_SAMESITE=lax

CSRF_ENFORCED=false
CSRF_COOKIE_NAME=csrfToken
CSRF_HEADER_NAME=X-CSRF-Token

AUTH_VALIDATE_ORIGIN=false
PERMISSIONS_BACKFILL_ON_START=true
PERMISSIONS_BACKFILL_FAIL_HARD=false

SETUP_ENABLE_ENDPOINT=true
SETUP_SECRET_KEY=tu_clave_secreta_para_setup_aqui

# =====================================================
# CONFIGURACION DE CORS
# =====================================================

CORS_ORIGIN=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# =====================================================
# CONFIGURACION DE EMAIL
# =====================================================

EMAIL_HOST=smtp-relay.sendinblue.com
EMAIL_PORT=587
EMAIL_USER=tu-usuario-smtp
EMAIL_PASS=tu-clave-smtp
EMAIL_FROM=matriz.inmobiliaria001@gmail.com
EMAIL_LOGO_URL=https://matrizinmobiliaria.com/images/logo-matriz-sin-fondo.png

INVITATION_URL_BASE=http://localhost:3000/activar
EMAIL_VERIFICATION_URL_BASE=http://localhost:3000/verificar-correo

INVITATION_TTL_HOURS=24
INVITATION_MAX_INTENTOS=5
EMAIL_VERIFICATION_MAX_CODES=5
EMAIL_SEND_RETRY_ATTEMPTS=3
EMAIL_SEND_RETRY_BASE_DELAY_MS=2000

# =====================================================
# CONFIGURACION DE RATE LIMITING
# =====================================================

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_GENERAL_MAX_REQUESTS=1000
RATE_LIMIT_AUTH_ME_MAX_REQUESTS=500
RATE_LIMIT_SSE_CONNECT_MAX_REQUESTS=100

# =====================================================
# CONFIGURACION DE LOGS
# =====================================================

LOG_LEVEL=warn
LOG_FILE_PATH=./logs

# =====================================================
# CLOUDINARY
# =====================================================

CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret
